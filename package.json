{
  "name": "@waits/legacylens",
  "version": "0.4.1",
  "description": "RAG-powered CLI for understanding legacy codebases (LAPACK + NASA cFS)",
  "type": "module",
  "bin": {
    "legacylens": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --outdir dist --target node",
    "prepublishOnly": "bun run build",
    "ingest": "bun run src/ingestion/ingest.ts",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && changeset publish"
  },
  "keywords": [
    "legacy-code",
    "rag",
    "lapack",
    "nasa",
    "cfs",
    "cli"
  ],
  "author": "Ryan Waits",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "0.78.0",
    "@supabase/supabase-js": "2.98.0",
    "chalk": "5.6.2",
    "commander": "14.0.3",
    "emphasize": "7.0.0",
    "marked": "17.0.3",
    "openai": "6.25.0",
    "ora": "9.3.0"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
