{
  "name": "@waits/legacylens",
  "version": "1.0.0",
  "description": "RAG-powered CLI for understanding legacy codebases (LAPACK + NASA cFS)",
  "type": "module",
  "bin": {
    "legacylens": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --outdir dist --target node",
    "prepublishOnly": "bun run build",
    "ingest": "bun run src/ingestion/ingest.ts"
  },
  "keywords": ["legacy-code", "rag", "lapack", "nasa", "cfs", "cli"],
  "author": "Ryan Waits",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "0.78.0",
    "@supabase/supabase-js": "2.98.0",
    "chalk": "5.6.2",
    "commander": "14.0.3",
    "emphasize": "7.0.0",
    "marked": "17.0.3",
    "openai": "6.25.0",
    "ora": "9.3.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
